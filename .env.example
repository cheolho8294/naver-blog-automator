# 복사해서 .env.local 로 저장 (로컬) 또는 Vercel → Settings → Environment Variables 에 동일 이름으로 등록

# --- 필수: AI 키 중 하나 ---
# OpenRouter 사용 시 (https://openrouter.ai 크레딧·API 키)
OPENROUTER_API_KEY=

# OpenRouter 대신 Anthropic 직통만 쓸 때만 (둘 중 하나만 채우면 됨. OPENROUTER 가 있으면 OpenRouter 우선)
# ANTHROPIC_API_KEY=

# --- 선택: OpenRouter 세부 설정 ---
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_HTTP_REFERER=https://본인-배포-url.vercel.app
# OPENROUTER_APP_TITLE=Naver Blog Automator
# OPENROUTER_MODEL_AUTOFILL=
# OPENROUTER_MODEL_BLOG=

# --- 선택: Anthropic 직통일 때만 ---
# ANTHROPIC_MODEL_AUTOFILL=claude-sonnet-4-6
# ANTHROPIC_MODEL_BLOG=claude-sonnet-4-6

# --- 선택: 글 생성 시 웹 검색 스니펫(Tavily) ---
# TAVILY_API_KEY=

# Vercel 은 배포 시 VERCEL_URL 을 자동 주입합니다 (로컬에는 없어도 됨).
